# Aura Intelligence - Deployment Configuration Template

# --- FRONTEND (.env in frontend directory) ---
# VITE_API_URL=http://your-node-backend-url.com
# VITE_ML_API_URL=http://your-flask-ml-url.com

# --- NODE BACKEND (.env in backend directory) ---
# PORT=5000
# ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# --- ML BACKEND (.env in ml-backend directory) ---
# PORT=5001
# FLASK_ENV=production
# ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.com
# OPENWEATHER_API_KEY=your_key_here
